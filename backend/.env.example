# Copy to `.env` in this directory (same folder as `manage.py`).

DJANGO_SECRET_KEY=django-insecure-estudia-mas-dev-only-change-me-32b+
DJANGO_DEBUG=true
DJANGO_TIME_ZONE=America/Mexico_City
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver

# DATABASE_URL=postgres://estudia:estudia@127.0.0.1:5432/estudia_mas

CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DJANGO_BEHIND_PROXY=false

FRONTEND_URL=http://localhost:5173

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@localhost
EMAIL_PUBLIC_BASE_URL=http://127.0.0.1:8000
EMAIL_BRAND_NAME=Estudia Más

REGISTRATION_REQUIRE_EMAIL_ACTIVATION=true
REGISTRATION_OPEN=true

JWT_REFRESH_COOKIE_NAME=refresh_token
JWT_COOKIE_SAMESITE=Lax
