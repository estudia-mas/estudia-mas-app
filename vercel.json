{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "demo": {
      "root": "demo",
      "framework": "vite",
      "installCommand": "npm ci",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "rewrites": [
        {
          "source": "/((?!assets/).*)",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "/assets/(.*)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "demo"
      }
    }
  ]
}
